# Optional: admin key that can also read endpoint events.
# Endpoint creation is public and does not require this key.
# WEBHOOK_CATCHER_API_KEY=replace-with-a-long-random-value

# Required: secret used to derive write secrets and sign read/cursor tokens.
WEBHOOK_CATCHER_SIGNING_SECRET=replace-with-a-different-long-random-value

# Required on Vercel if you want explicit region pinning.
# Keep send + receive on the same queue region.
WEBHOOK_CATCHER_QUEUE_REGION=iad1

# Optional: local/dev token override for Vercel Queue API auth.
# On Vercel, OIDC auth is used automatically.
# WEBHOOK_CATCHER_QUEUE_TOKEN=

# Optional capture + token settings.
WEBHOOK_CATCHER_EVENT_RETENTION_SECONDS=86400
WEBHOOK_CATCHER_MAX_CAPTURE_BYTES=65536
WEBHOOK_CATCHER_READ_TOKEN_TTL_SECONDS=2592000
WEBHOOK_CATCHER_CURSOR_TOKEN_TTL_SECONDS=604800

# Optional absolute base URL used in create endpoint responses.
# WEBHOOK_CATCHER_BASE_URL=https://your-app.vercel.app
